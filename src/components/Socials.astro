---
import { SOCIALS } from "@/constants";
import LinkButton from "./LinkButton.astro";

export interface Props {
  centered?: boolean;
}

const { centered = false } = Astro.props;
---

<div class:list={["flex-wrap justify-center gap-1", { flex: centered }]}>
  {
    SOCIALS.map(social => (
      <LinkButton
        href={social.href}
        class="p-2 hover:rotate-6 sm:p-1"
        title={social.linkTitle}
      >
        <social.icon class:list={[
          "inline-block size-6 fill-transparent stroke-current opacity-90 group-hover:fill-transparent",
          social.name === "RSS" ? "scale-125 stroke-[2.6] sm:scale-110" : "scale-125 stroke-2 sm:scale-110"
        ]} />
        <span class="sr-only">{social.linkTitle}</span>
      </LinkButton>
    ))
  }
</div>
